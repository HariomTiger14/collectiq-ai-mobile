# ENVIRONMENT/APP_VERSION/COMMIT_SHA are deployment-friendly aliases.
# BACKEND_ENV/BACKEND_VERSION/GIT_COMMIT remain backward-compatible.
ENVIRONMENT=local
BACKEND_ENV=local
APPLICATION_NAME=PackLox API
APP_VERSION=0.1.0
BACKEND_VERSION=0.1.0
COMMIT_SHA=unknown
GIT_COMMIT=unknown
BUILD_TIME=unknown
PUBLIC_API_URL=http://127.0.0.1:8000
PUBLIC_FRONTEND_URL=http://localhost:3000
PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000,https://sit.packlox.com,https://admin.packlox.com
HEALTH_TIMEOUT_SECONDS=3
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_HEALTH_REQUIRED=false

AI_PROVIDER=mock
PRICING_PROVIDER=mock

# Future server-side AI provider settings. Never place these values in Flutter.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30

# Server-side pricing provider settings. Never place these values in Flutter.
EBAY_ACCESS_TOKEN=
EBAY_BROWSE_API_URL=https://api.ebay.com/buy/browse/v1/item_summary/search
EBAY_MARKETPLACE_ID=EBAY_AU
EBAY_TIMEOUT_SECONDS=10
TCGPLAYER_CLIENT_ID=
TCGPLAYER_CLIENT_SECRET=
TCGPLAYER_API_BASE=https://api.tcgplayer.com
TCGPLAYER_TIMEOUT_SECONDS=10
PRICECHARTING_API_KEY=
PRICECHARTING_API_BASE=https://www.pricecharting.com
PRICECHARTING_TIMEOUT_SECONDS=10
PRICING_CACHE_TTL_SECONDS=900
PRICING_PROVIDER_MIN_INTERVAL_MS=250
