# Copy this file to config/sit.env and fill in DEV/SIT values.
# Do not commit config/sit.env.

SUPABASE_URL=https://ljrkhamgbgtsicqdisos.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Backend base URL used by scanner/backend AI clients.
# Leave unset to use the live SIT backend default:
# https://api-sit.packlox.com
#
# Set this only when intentionally testing a local backend from a physical phone.
# API_BASE_URL=http://YOUR-LAN-IP:8000

# Optional backend-only AI endpoint override for provider validation.
# Do not put provider API keys in this app config.
# Leave unset in normal SIT builds so the app calls:
# https://api-sit.packlox.com/analyze
# AI_BACKEND_ANALYSIS_ENDPOINT_URL=http://YOUR-LAN-IP:8000/analyze
