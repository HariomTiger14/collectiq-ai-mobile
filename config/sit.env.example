# Copy this file to config/sit.env and fill in DEV/SIT values.
# Do not commit config/sit.env.

SUPABASE_URL=https://YOUR-DEV-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Backend base URL used by the existing scanner/backend AI client.
# For a physical phone, use your computer's LAN IP and ensure the backend is reachable.
API_BASE_URL=http://YOUR-LAN-IP:8000

# Optional backend-only AI endpoint for future provider validation.
# Do not put provider API keys in this app config.
# AI_BACKEND_ANALYSIS_ENDPOINT_URL=http://YOUR-LAN-IP:8000/api/analyze
