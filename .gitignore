# Miscellaneous
*.class
*.log
*.pyc
__pycache__/
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
!build/web/auth/reset-password/
/coverage/

# Runtime uploads from the local scanner backend.
/uploads/
/audit_uploads/
/backend/audit_uploads/
.venv/
.env

# Local/SIT build configuration. Commit only the safe *.example templates.
/config/*.env
!/config/*.env.example

# Validation lab local datasets. Keep scripts/manifests/docs in git, but never
# commit imported image files or large dataset exports.
/validation/images/**
!/validation/images/
!/validation/images/.gitkeep
/validation/reports/*
!/validation/reports/
!/validation/reports/.gitkeep
/validation/datasets/
/validation/downloads/
/validation/exports/
/validation/raw/
/validation/tmp/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local diagnostic artifacts from Android/SIT debugging.
/.codex/
/.tmp_bugreport_packlox/
/bugreport-*.zip
/*.png
/*logcat*.txt
/traces.txt
/test-output.txt
/widget_test_full.txt
/window*.xml
/window_*.xml
/*dumpstate*
/*anr*
/*tombstone*
/*recovery*.txt
